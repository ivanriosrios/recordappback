# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/recordapp

# Redis
REDIS_URL=redis://localhost:6379/0

# WhatsApp Cloud API (Meta — legacy)
WHATSAPP_TOKEN=your_whatsapp_cloud_api_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token

# Twilio (nuevo proveedor de mensajería)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=your_api_key_secret
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_WEBHOOK_AUTH_TOKEN=your_twilio_auth_token_for_webhook_validation

# Proveedor de mensajería activo: "twilio" o "meta"
MESSAGING_PROVIDER=twilio

# JWT Auth
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App
APP_NAME=RecordApp
DEBUG=true
